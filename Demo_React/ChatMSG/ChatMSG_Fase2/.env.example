# URL de conexión a Redis
# Para usar Redis local:      redis://localhost:6379
# Para usar Redis remoto:     redis://usuario:password@host:6379
# Para usar Redis con TLS:    rediss://usuario:password@host:6380
REDIS_URL=redis://localhost:6379

# Secreto para firmar las cookies de sesión (cambia esto en producción)
SESSION_SECRET=change-this-to-a-secure-random-string

# Origen permitido del cliente (frontend)
CLIENT_ORIGIN=http://localhost:5173

# Puerto del servidor Express
PORT=4000
